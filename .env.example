# .env.example
# Example environment variables
# DO NOT commit real secrets or production keys

# Google Maps
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Firebase Config
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_VAPID_KEY=your_firebase_vapid_key

# API / App Settings
VITE_API_BASE_URL=https://api.example.com
VITE_SOCKET_URL=https://your-socket-server.example.com
VITE_ENVIRONMENT=development
VITE_ENABLE_ANALYTICS=false

# Auth endpoints (refresh token is HttpOnly cookie; backend must set it on login)
VITE_AUTH_REFRESH_PATH=/auth/refresh-token
VITE_AUTH_LOGOUT_PATH=/auth/logout